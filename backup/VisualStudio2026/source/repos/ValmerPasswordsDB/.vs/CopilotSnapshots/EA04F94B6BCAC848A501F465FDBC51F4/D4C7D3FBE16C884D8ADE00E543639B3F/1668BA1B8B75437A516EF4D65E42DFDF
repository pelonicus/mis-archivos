        // ==========================================
        // SISTEMA DE BLOQUEO (LOCK) DE 5 MINUTOS
        // ==========================================
        private bool VerificarYTomarLock()
        {
            string lockPath = GetLockPath();
            if (string.IsNullOrEmpty(lockPath)) return false;
            try
            {
                if (File.Exists(lockPath))
                {
                    string[] lines = File.ReadAllLines(lockPath);
                    if (lines.Length >= 2 && DateTime.TryParse(lines[0], out DateTime timestamp))
                    {
                        if ((DateTime.Now - timestamp).TotalMinutes < 5)
                        {
                            MessageBox.Show($"Este registro está siendo editado por {lines[1]}.\nIniciado a las {timestamp:HH:mm:ss}.", "Bloqueo Activo", MessageBoxButton.OK, MessageBoxImage.Warning);
                            return false;
                        }
                    }
                }
                File.WriteAllLines(lockPath, new string[] { DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"), Environment.UserName });
                return true;
            }
            catch { return false; }
        }

        private void LiberarLock()
        {
            try { string path = GetLockPath(); if (File.Exists(path)) File.Delete(path); } catch { }
        }

        private bool ValidarLockParaGuardar()
        {
            string lockPath = GetLockPath();
            if (!File.Exists(lockPath)) return false;
            try
            {
                string[] lines = File.ReadAllLines(lockPath);
                if (lines.Length >= 2 && DateTime.TryParse(lines[0], out DateTime time))
                {
                    if ((DateTime.Now - time).TotalMinutes > 5)
                    {
                        MessageBox.Show("Lock Timeout: Tiempo de edición expirado. Cambios no guardados.", "Error", MessageBoxButton.OK, MessageBoxImage.Error);
                        return false;
                    }
                    return lines[1] == Environment.UserName;
                }
                return false;
            }
            catch { return false; }
        }

