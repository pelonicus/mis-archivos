        private void BtnAddFilaUsuario_Click(object sender, RoutedEventArgs e) => AgregarFilaEdicionUsuario("", "");

        private void AgregarFilaEdicionUsuario(string user, string passDec)
        {
            var grid = new Grid { Margin = new Thickness(0, 0, 0, 10) };
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) }); // User
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) }); // Pass
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) }); // Confirm
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(35) }); // Ojo
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(45) }); // Check Status
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(35) }); // Trash

            var txtU = new TextBox { Text = user, Margin = new Thickness(2), Padding = new Thickness(3) };
            var pwdP = new PasswordBox { Password = passDec, Margin = new Thickness(2), Padding = new Thickness(3) };
            var pwdC = new PasswordBox { Password = passDec, Margin = new Thickness(2), Padding = new Thickness(3) };
            var txtPVis = new TextBox { Text = passDec, Margin = new Thickness(2), Padding = new Thickness(3), Visibility = Visibility.Collapsed };
            var txtCVis = new TextBox { Text = passDec, Margin = new Thickness(2), Padding = new Thickness(3), Visibility = Visibility.Collapsed };

            // Icono de estado (Cruz Roja / Check Verde)
            bool okInit = !string.IsNullOrEmpty(passDec);
            var icoStatus = new TextBlock { Text = okInit ? "✅" : "❌", Foreground = okInit ? Brushes.Green : Brushes.Red, VerticalAlignment = VerticalAlignment.Center, HorizontalAlignment = HorizontalAlignment.Center, FontSize = 14 };

            RoutedEventHandler val = (s, e) => {
                bool ok = !string.IsNullOrEmpty(pwdP.Password) && pwdP.Password == pwdC.Password;
                icoStatus.Text = ok ? "✅" : "❌"; icoStatus.Foreground = ok ? Brushes.Green : Brushes.Red;
            };
            pwdP.PasswordChanged += val; pwdC.PasswordChanged += val;

            var btnEye = new Button { Content = "👁", Margin = new Thickness(2), Cursor = Cursors.Hand };
            btnEye.PreviewMouseDown += (s, e) => {
                txtPVis.Text = pwdP.Password; txtCVis.Text = pwdC.Password;
                pwdP.Visibility = pwdC.Visibility = Visibility.Collapsed; txtPVis.Visibility = txtCVis.Visibility = Visibility.Visible;
            };
            btnEye.PreviewMouseUp += (s, e) => {
                pwdP.Visibility = pwdC.Visibility = Visibility.Visible; txtPVis.Visibility = txtCVis.Visibility = Visibility.Collapsed;
            };

            var btnDel = new Button { Content = "🗑", Margin = new Thickness(2), Foreground = Brushes.Red, Cursor = Cursors.Hand };
            btnDel.Click += (s, e) => ContenedorUsuariosEdicion.Children.Remove(grid);

            Grid.SetColumn(txtU, 0);
            Grid.SetColumn(pwdP, 1); Grid.SetColumn(txtPVis, 1);
            Grid.SetColumn(pwdC, 2); Grid.SetColumn(txtCVis, 2);
            Grid.SetColumn(btnEye, 3); Grid.SetColumn(icoStatus, 4); Grid.SetColumn(btnDel, 5);

            grid.Children.Add(txtU); grid.Children.Add(pwdP); grid.Children.Add(txtPVis);
            grid.Children.Add(pwdC); grid.Children.Add(txtCVis); grid.Children.Add(btnEye);
            grid.Children.Add(icoStatus); grid.Children.Add(btnDel);

            // Guardamos la info de la fila en su Tag para leerla al guardar
            grid.Tag = new FilaUsuarioData { TxtUser = txtU, PwdPass = pwdP, PwdConf = pwdC, ContrasenaAntiguaEncriptada = Encriptar(passDec) };

            ContenedorUsuariosEdicion.Children.Add(grid);
        }

        private void BtnAddServidorDesdeGrupo_Click(object sender, RoutedEventArgs e)
        {
            if (!VerificarYTomarLock()) return;
            _grupoSeleccionadoParaNuevo = (XElement)((Button)sender).Tag; _servidorEditando = null;
            TxtNombre.Text = TxtIP.Text = TxtURL.Text = TxtComentario.Text = TxtDominio.Text = TxtHardwareTipo.Text = TxtLlave.Text = ""; ComboTipo.SelectedIndex = 0;
            ContenedorUsuariosEdicion.Children.Clear(); AgregarFilaEdicionUsuario("", ""); // Agrega una fila vacía
            TxtTituloDerecho.Text = "Nuevo Servidor"; ScrollModoVer.Visibility = Visibility.Collapsed; ScrollModoEdicion.Visibility = Visibility.Visible; TxtMensajeVacio.Visibility = Visibility.Collapsed;
        }

        private void BtnActivarEdicion_Click(object sender, RoutedEventArgs e)
        {
            if (_servidorEditando == null || !VerificarYTomarLock()) return;
            TxtTituloDerecho.Text = "Editar Registro";

            string t = _servidorEditando.Attribute("tipo")?.Value; foreach (ComboBoxItem i in ComboTipo.Items) if (i.Content.ToString() == t) ComboTipo.SelectedItem = i;
            TxtNombre.Text = _servidorEditando.Attribute("nombre")?.Value; TxtIP.Text = _servidorEditando.Attribute("ip")?.Value; TxtURL.Text = _servidorEditando.Attribute("url")?.Value;
            TxtComentario.Text = _servidorEditando.Element("Comentario")?.Value; TxtDominio.Text = _servidorEditando.Attribute("dominio")?.Value;
            TxtHardwareTipo.Text = _servidorEditando.Attribute("hw_tipo")?.Value; TxtLlave.Text = _servidorEditando.Element("LlaveSSH")?.Value;

            ContenedorUsuariosEdicion.Children.Clear();
            var usuarios = _servidorEditando.Elements("Usuario").ToList();
            if (usuarios.Count == 0) AgregarFilaEdicionUsuario("", "");
            foreach (var u in usuarios)
            {
                string pEnc = u.Elements("Password").FirstOrDefault(x => x.Attribute("activa")?.Value == "true")?.Value ?? "";
                AgregarFilaEdicionUsuario(u.Attribute("nombre")?.Value, Desencriptar(pEnc));
            }
            ScrollModoVer.Visibility = Visibility.Collapsed; ScrollModoEdicion.Visibility = Visibility.Visible;
        }

        private void BtnGuardarServidor_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(TxtNombre.Text) || _xmlData == null) return;
            if (!ValidarLockParaGuardar()) { LiberarLock(); ScrollModoEdicion.Visibility = Visibility.Collapsed; TxtMensajeVacio.Visibility = Visibility.Visible; return; }

            // Recopilar y validar todas las filas de usuarios
            var nuevosUsuarios = new List<XElement>();
            foreach (Grid grid in ContenedorUsuariosEdicion.Children)
            {
                var data = (FilaUsuarioData)grid.Tag;
                string u = data.TxtUser.Text.Trim(); string p1 = data.PwdPass.Password; string p2 = data.PwdConf.Password;
                if (string.IsNullOrEmpty(u) && string.IsNullOrEmpty(p1)) continue; // Fila vacía ignorada

                if (p1 != p2) { MessageBox.Show($"Las contraseñas para el usuario '{u}' no coinciden.", "Error", MessageBoxButton.OK, MessageBoxImage.Warning); return; }
                if (string.IsNullOrEmpty(p1)) { MessageBox.Show($"La contraseña para el usuario '{u}' no puede estar vacía.", "Error", MessageBoxButton.OK, MessageBoxImage.Warning); return; }

                string encP = p1 == Desencriptar(data.ContrasenaAntiguaEncriptada) ? data.ContrasenaAntiguaEncriptada : Encriptar(p1);
                nuevosUsuarios.Add(new XElement("Usuario", new XAttribute("nombre", u), new XElement("Password", encP, new XAttribute("activa", "true"))));
            }

            if (nuevosUsuarios.Count == 0) { MessageBox.Show("Debe agregar al menos un usuario.", "Aviso", MessageBoxButton.OK, MessageBoxImage.Warning); return; }

            string uAct = Environment.UserName; string fH = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            if (_servidorEditando == null)
            {
                _servidorEditando = new XElement("Servidor"); var h = new XElement("Historial"); _servidorEditando.Add(h);
                RegistrarEventoHistorial(h, "Creación de Servidor", uAct, fH);
                _grupoSeleccionadoParaNuevo?.Add(_servidorEditando);
            }
            else
            {
                var h = _servidorEditando.Element("Historial"); if (h == null) { h = new XElement("Historial"); _servidorEditando.AddFirst(h); }
                RegistrarEventoHistorial(h, "Actualización de Registro y/o Usuarios", uAct, fH);
                _servidorEditando.Elements().Where(x => x.Name != "Historial").Remove();
            }

            _servidorEditando.SetAttributeValue("tipo", (ComboTipo.SelectedItem as ComboBoxItem)?.Content.ToString());
            _servidorEditando.SetAttributeValue("nombre", TxtNombre.Text); _servidorEditando.SetAttributeValue("ip", TxtIP.Text); _servidorEditando.SetAttributeValue("url", TxtURL.Text);
            _servidorEditando.SetAttributeValue("dominio", TxtDominio.Text); _servidorEditando.SetAttributeValue("hw_tipo", TxtHardwareTipo.Text);
            _servidorEditando.Add(new XElement("Comentario", TxtComentario.Text), new XElement("LlaveSSH", TxtLlave.Text));
            _servidorEditando.Add(nuevosUsuarios); // Agregamos todos los usuarios

            GuardarXML(); LiberarLock(); CargarDatosXML();
            ScrollModoEdicion.Visibility = Visibility.Collapsed; TxtMensajeVacio.Visibility = Visibility.Visible;
        }

        private void BtnCerrarForm_Click(object sender, RoutedEventArgs e) { LiberarLock(); ScrollModoEdicion.Visibility = Visibility.Collapsed; TxtMensajeVacio.Visibility = Visibility.Visible; }

        private void RegistrarEventoHistorial(XElement h, string ac, string au, string f) => h.AddFirst(new XElement("Evento", new XAttribute("fecha", f), new XAttribute("accion", ac), new XAttribute("autor", au)));

        private void GuardarXML()
        {
            try
            {
                string ruta = GetXmlPath();
                if (!string.IsNullOrEmpty(ruta) && _xmlData != null)
                {
                    string tempFile = ruta + ".tmp";
                    using (FileStream fs = new FileStream(tempFile, FileMode.Create, FileAccess.Write, FileShare.None)) { _xmlData.Save(fs); }
                    if (File.Exists(ruta)) File.Delete(ruta);
                    File.Move(tempFile, ruta);
                }
            }
            catch (Exception ex) { MessageBox.Show("Error al guardar: " + ex.Message); }
        }

        private void BtnAddGrupo_Click(object sender, RoutedEventArgs e)
        {
            string n = Microsoft.VisualBasic.Interaction.InputBox("Nombre Grupo:", "Nuevo Grupo");
            if (!string.IsNullOrWhiteSpace(n))
            {
                var g = new XElement("Grupo", new XAttribute("nombre", n)); var h = new XElement("Historial");
                RegistrarEventoHistorial(h, "Creación de Grupo", Environment.UserName, DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
                g.Add(h); _xmlData?.Root?.Add(g); GuardarXML(); CargarDatosXML();
            }
        }

        private string Encriptar(string t) { using Aes aes = Aes.Create(); byte[] k = new byte[32]; Array.Copy(Encoding.UTF8.GetBytes(MasterKey), k, Math.Min(MasterKey.Length, 32)); aes.Key = k; aes.IV = new byte[16]; using var enc = aes.CreateEncryptor(); byte[] b = Encoding.UTF8.GetBytes(t); return Convert.ToBase64String(enc.TransformFinalBlock(b, 0, b.Length)); }
        private string Desencriptar(string b64) { try { using Aes aes = Aes.Create(); byte[] k = new byte[32]; Array.Copy(Encoding.UTF8.GetBytes(MasterKey), k, Math.Min(MasterKey.Length, 32)); aes.Key = k; aes.IV = new byte[16]; using var dec = aes.CreateDecryptor(); byte[] b = Convert.FromBase64String(b64); return Encoding.UTF8.GetString(dec.TransformFinalBlock(b, 0, b.Length)); } catch { return ""; } }
    }
