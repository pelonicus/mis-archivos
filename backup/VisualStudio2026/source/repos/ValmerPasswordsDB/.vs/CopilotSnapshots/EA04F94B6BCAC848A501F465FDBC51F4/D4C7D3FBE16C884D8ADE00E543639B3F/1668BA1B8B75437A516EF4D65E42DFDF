            var usuarios = s.Elements("Usuario").ToList();
            if (usuarios.Count == 0) ContenedorUsuariosVer.Children.Add(new TextBlock { Text = "No hay usuarios registrados.", FontStyle = FontStyles.Italic, Foreground = Brushes.Gray });

            foreach (var u in usuarios)
