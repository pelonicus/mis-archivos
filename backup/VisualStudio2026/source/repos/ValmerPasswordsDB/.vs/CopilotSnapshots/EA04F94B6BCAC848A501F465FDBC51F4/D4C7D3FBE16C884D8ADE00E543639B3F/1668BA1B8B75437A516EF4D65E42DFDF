            PanelVerLlave.Visibility = string.IsNullOrEmpty(TxtVerLlave.Text) ? Visibility.Collapsed : Visibility.Visible;
            LblVerComentarios.Text = s.Element("Comentario")?.Value ?? "-";

            // Generar filas de usuarios dinámicamente
